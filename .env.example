# 이 파일을 복사해 .env 를 만든 뒤 값을 채우세요. (.env 는 git 에 올리지 마세요.)
# 여기에는 실제 APP_KEY / 시크릿 / 텔레그램 토큰을 넣지 마세요.

# --- KIS ---
# 실전: KIS_ENV=prod + 개발자포털 [실전투자] 앱의 APP_KEY/APP_SECRET + 실계좌 ACCOUNT_NO
# 모의: KIS_ENV=vts + [모의투자] 앱 키 + 모의계좌 (실전 키로 vts 호출 시 EGW02007)
APP_KEY=PSpSXUWUVbDLXiI34zFT1OuK7MSd4qVh60X5
APP_SECRET=8EpxKRf0rnIaoFzqtz7nLO5JOD+DMXk5H2h7289ctv2LZ2hyzjzoZi09z1J+VUzGWiJL6WaDS33RWsiHXxSA1Emvqq2ZTyZGmtajkMrts8lwdg1HhjkkD83EvHZ6foEFwQyy1AE3VuS/9xUASOCM/QYhYe4haezolgo2FJ9/H/6D7xhHWdw=
ACCOUNT_NO=12345678-01
KIS_ENV=prod
PRODUCT_CODE=01
# 국내 잔고조회 HTTP 500 시: 한투 예시는 PRCS_DVSN=00 (코드 기본값). 계속 500이면 KIS_BALANCE_INQR_DVSN=01 또는 OFL_YN=N 등 문서대로 시도.
# KIS_BALANCE_PRCS_DVSN=00
# KIS_BALANCE_INQR_DVSN=02
# KIS_BALANCE_OFL_YN=
# KIS_BALANCE_HTTP_RETRIES=2
# 현금주문: 공식 샘플은 EXCG_ID_DVSN_CD=KRX + TR_ID TTTC0012U(매수)/TTTC0011U(매도). HTTP 500 시 구 TR_ID:
# KIS_ORDER_LEGACY_TR_ID=true
# KIS_ORDER_EXCG_ID_DVSN_CD=KRX
# KIS_ORDER_TR_ID_BUY=
# KIS_ORDER_TR_ID_SELL=

# --- 자본·비중 (리포트·가이드용) ---
BASE_CAPITAL_KRW=1000000
KOR_WEIGHT=0.7
USA_WEIGHT=0.3
MAX_OPEN_POSITIONS=3
# 슬롯 만석일 때 보유 종목만 엔진+TA 매수조건 재평가 ([보유진단] 로그). false면 기존 SKIP_BUY만 출력
TRADING_SCAN_HELD_ENTRY=true
MAX_SINGLE_LOSS_PCT=0.10
MAX_DAILY_LOSS_PCT=0.15
STOP_LOSS_PCT=0.20
# ↑ 가이드용(리포트 등). 실제 하드스탑은 아래 TRADING_STOP_LOSS_PCT 만 loader 가 읽음.
TAKE_PROFIT_PCT=0.25
MAX_CONSECUTIVE_STOP_LOSS=3
JOURNAL_PATH=logs/trade_journal.csv
# 대시보드 (장마감): reports/dashboard_eod.html + trade_export_YYYY-MM-DD.csv
EOD_BUILD_DASHBOARD=true
EOD_DASHBOARD_PATH=reports/dashboard_eod.html
# market_watch 가 KST 15:35 이후 자동 생성 (AWS UTC 서버도 OK). 크론 백업: scripts/cron_eod_kr.sh
EOD_AUTO_BUILD=true
EOD_AUTO_BUILD_AFTER_KST=15:35
# EOD_AUTO_BUILD_STATE_PATH=logs/eod_build_state.json
# EOD_TELEGRAM_NOTIFY=true
# Mac에서 받기: scp user@ec2:~/자동매매/reports/dashboard_eod.html ./reports/
# S3 업로드(선택, aws CLI 필요): EOD_S3_BUCKET=my-bucket
# EOD_S3_PREFIX=autotrade/reports/
DASHBOARD_QUOTES_KIS=true
HOLDINGS_QUOTES_PATH=logs/holdings_quotes.json
# 실시간(옵션): market_watch 사이클마다 시세 JSON. http://...?live=1 과 함께 사용
DASHBOARD_AUTO_SYNC=false

# --- 실행 모드 + 1분 자동매매 스킴 (market_watch) ---
# 스킴: ① 후보 스캔 → ② 매도(조건 시) → ③ 매수(조건 시) → ④ 실매수 후 텔레(TELEGRAM_POST_BUY_REPORT)
# 반복 실행: 프로젝트 루트에서  python3 src/market_watch.py  (auto_trade.py 는 한 사이클만)
DRY_RUN=true
TEST_SYMBOL=005930
TEST_QTY=1
LIVE_ARM_PHRASE=
TRADING_WATCH=true
TRADING_WATCH_INTERVAL_SEC=60
# 맥 시계가 서울이 아니면 장중 판정이 어긋날 수 있음. 장외에도 드라이런 사이클만 돌릴 때:
# TRADING_WATCH_RUN_OUTSIDE_SESSION=true

# --- KST 당일 최소 1회 “주문 이벤트” (엔진이 NO_BUY 일 때만 강제 분기) ---
# 기본 false. 켜면 logs/daily_min_trade_state.json 으로 KST당일 주문 건수 추적.
FORCE_DAILY_TRADE=false
FORCE_DAILY_MIN_ORDERS=1
# KST 이 시각 이후에만 강제 시도 (0 이면 장중 언제든)
FORCE_DAILY_TRADE_AFTER_HOUR_KST=0
FORCE_DAILY_TRADE_SYMBOL=
FORCE_DAILY_TRADE_QTY=1
# FORCE_DAILY_TRADE_STATE_PATH=logs/daily_min_trade_state.json
# 실주문 강제(위험) — DRY_RUN=false 일 때만 의미 있음. 반드시 명시적으로 true
# FORCE_DAILY_TRADE_LIVE=false

# 실매매 시에만 주석 해제 (오타 없이)
# CONFIRM_LIVE=I_ACCEPT_ORDER_RISK

# --- 텔레그램 (③ 매수 후 ④ 보고) ---
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=8745718075:AAEyGUtk-c4juTzjTbveR-KIye1WwdQ2ipI
TELEGRAM_CHAT_ID=7574915440
TRADE_REASON=
# 실매매 매수·매도 체결 후 텔레 (한국투자 체결안내 형식, TELEGRAM_KIS_FILL_FORMAT=true)
TELEGRAM_POST_BUY_REPORT=true
TELEGRAM_POST_SELL_REPORT=true
TELEGRAM_KIS_FILL_FORMAT=true
# *계좌명: (미설정 시 -)
TELEGRAM_ACCOUNT_NAME=
# 체결 조회 대기·재시도(수량/단가 0 방지)
TELEGRAM_FILL_WAIT_SEC=3
TELEGRAM_FILL_POLL_RETRIES=4
# DRY_RUN 인데 엔진이 종목을 PICK 했을 때도 텔레 (1분마다 돌면 스팸될 수 있음 → 기본 false)
TELEGRAM_NOTIFY_PICK_DRY_RUN=false
# TELEGRAM_DRY_RUN_VALIDATION=false
# TELEGRAM_CYCLE_REPORT=true
# 매수 검증 실패·매도 주문 예외 등: 동일 종목·유형은 KST 당일 텔레 1회만(반복 스팸 방지). 끄면 매번 전송.
# TELEGRAM_FAIL_ALERT_DEDUP=true
# 상태 파일(재시작 후에도 유지). 비우면 기본 logs/telegram_fail_dedup.json
# TELEGRAM_FAIL_DEDUP_FILE=logs/telegram_fail_dedup.json

# --- 점수 통합: 엔진 + TA 조건별 가점(각각 독립 합산) ---
# combined = clamp(엔진 + TA매수가점 − TA매도감점(±14 등 동일표))×MULT. 청산: 매도2+·종가≤20일선
USE_TA_SIGNALS=true
USE_ENTRY_PIPELINE=true
TRADING_TA_POINT_MULT=1.0
# 매수 TA: 주요 시그널 최소 개수(미설정 시 watchlist min_signals, 보통 2). 1이면 단일 시그널 매수(구동작).
TRADING_TA_ENTRY_MIN_SIGNALS=2
TRADING_TA_ENTRY_ONLY=false
TRADING_TA_SELL_SCORE_MIN=28
SIGNAL_WATCHLIST_PATH=config/watchlist.json

# --- 자동 한 사이클 (국내 KR) ---
AUTO_MARKET=KR
# 수동 후보가 있으면 FDR 자동 스캔보다 우선합니다.
# AUTO_TRADE_SYMBOLS=005930,000660
# --- KRX 자동 탐색: AUTO_TRADE_SYMBOLS 를 비운 뒤 아래 주석 해제 ---
AUTO_SCAN_ENABLED=true
AUTO_SCAN_MAX_SYMBOLS=120
# 시총 정렬 후 상위에서 가져올 최대 종목 수(1~300). 후보가 적으면 필터(특히 AUTO_SCAN_MAX_PRICE_KRW)를 완화하거나 이 값·POOL_TOP을 키우세요.
AUTO_SCAN_POOL_TOP=800
# 필터 적용 뒤 Marcap 상위 몇 개까지 풀에 넣을지(≥ MAX_SYMBOLS 권장).
AUTO_SCAN_MAX_PRICE_KRW=50000
# 저가주 스캔: 종가 ≤ 위 금액(원). 시총 하한은 TRADING_MIN_MCAP_BN(또는 미설정 시 AUTO_SCAN_MIN_MCAP_BN).
AUTO_SCAN_MIN_MCAP_BN=0.1
AUTO_SCAN_RANDOM_SAMPLE=false
# true: 매 사이클마다 시총 상위 풀에서 무작위 N종(종목 편차 큼). false(권장): Marcap 상위 N종 고정.
UNIVERSE_LISTING_CACHE_SEC=3600
AUTO_UNIVERSE_FILE=config/universe.txt
AUTO_RUN_SELLS=true
USE_ENTRY_PIPELINE=true
USE_ADAPTIVE_REGIME=false
ADAPTIVE_REGIME_STATE_PATH=logs/adaptive_regime_state.json
USE_RS_RANKING=false
SKIP_BUY_IF_HELD=true
TRADING_ALLOW_HELD_TOPUP=true
TRADING_SKIP_BUY_IF_POSITION_STATE=false
# --- 자본·사이징 ---
# 예: NAV 20만·TRADING_MAX_RISK_PER_TRADE_PCT=0.05 → 허용손실 약 1만원. TRADING_SIZING_NAV_USE_REAL_BELOW_KRW 로 작은 설정 NAV는 KIS순자산으로 대체.
TRADING_SIZING_NAV_KRW=200000
# 설정 TRADING_SIZING_NAV_KRW가 아래(원) 미만이면 KIS nass_amt(순자산)으로 사이징(실순자산>0일 때). 실전 전환 시 켜 두는 것을 권장.
TRADING_SIZING_NAV_USE_REAL_BELOW_KRW=500000

# --- 수수료 (소수) ---
COMMISSION_KR_ONEWAY=0.00147
COMMISSION_US_ONEWAY=0.0025

# --- 매매 규칙 (매도) — TRADING_STOP_LOSS_PCT = TRADING_HARD_STOP_PCT (하위 호환) ---
TRADING_HARD_STOP_PCT=0.075
TRADING_SOFT_STOP_PCT=0.055
TRADING_SOFT_STOP_ENABLED=true
TRADING_SOFT_STOP_MA_CONFIRM=true
TRADING_SOFT_STOP_RATIO=0.50
TRADING_TP1_PCT=0.14
TRADING_TP1_RATIO=0.40
TRADING_TP2_PCT=0.28
TRADING_TP2_RATIO=0.30
TRADING_TRAIL_ACTIVATE_PCT=0.12
TRADING_TRAIL_W1_PCT=0.13
TRADING_TRAIL_W2_PCT=0.11
TRADING_TRAIL_W3_PCT=0.09
TRADING_TRAIL_STAGE2_FROM=0.28
TRADING_TRAIL_STAGE3_FROM=0.45
TRADING_USE_ATR_TRAILING=true
TRADING_ATR_TRAIL_MULT=2.3
TRADING_TIME_STOP_DAYS=15
TRADING_TIME_STOP_MIN_PNL=0.01
TRADING_TIME_STOP_EARLY_DAYS=5
TRADING_TIME_STOP_EARLY_LOSS_PCT=0.05
# 종목코드 % SPREAD → 보유일 = DAYS + (0..SPREAD-1), 예: 15+3=18일
TRADING_TIME_STOP_HASH_SPREAD=4
TRADING_TA_SELL_MIN_SIGNALS=2
TRADING_TA_SELL_SCORE_MIN=28
TRADING_TA_SELL_MA20_CONFIRM=true
TRADING_TA_SELL_COOLDOWN_H=4
TRADING_STOP_LOSS_PCT=0.075
TRADING_VIX_RISK_OFF=30
TRADING_VIX_TIGHT_TRAILING=35
# 트레이드당 포트 손실 상한(소수, .env 기본값). 로그의 risk_pct는 여기에 진입티어·VIX등 size_mult를 곱한 값임.
TRADING_MAX_RISK_PER_TRADE_PCT=0.05
# 사이징·엔진 하한용 최소 리스크 비율(소수). MAX 올릴 때 같이 올림
TRADING_MIN_RISK_PER_TRADE_PCT=0.03
TRADING_MAX_NAME_PCT=0.10
TRADING_MAX_SECTOR_PCT=0.25
# 시총 하한(십억 단위) 낮출 때 ROE 12%와 동시 적용이면 후보가 거의 없을 수 있음 → 테스트 시 ROE 완화
TRADING_MIN_ROE_PCT=8
TRADING_MIN_MCAP_BN=0.1
# ↑ 펀더멘털 필터 + FDR KRX 스캔 시총 하한(십억원). TRADING_MIN_MCAP_BN 미설정 시에만 AUTO_SCAN_MIN_MCAP_BN 사용.
TRADING_EXTRA_FORBIDDEN=규칙1|규칙2
#
# --- 스코어 엔진 ---
# 진입 문턱·국면·VIX: 기본 완화값 (구 TRADING_SCORE_FULL=80, HALF=65, REGIME_VETO=25, VIX_SOFT=22, SCALE_MID=0.75)
TRADING_W_TREND=0.3
TRADING_W_VOLUME=0.2
TRADING_W_REGIME=0.3
TRADING_W_SECTOR=0.1
TRADING_W_LIQUIDITY=0.1
TRADING_SCORE_FULL=75.0
TRADING_SCORE_HALF=75.0
TRADING_REGIME_VETO=10.0
TRADING_VIX_SOFT=25.0
TRADING_VIX_SCALE_MID=0.85
TRADING_REGIME_CAP_ABOVE=40
TRADING_REGIME_CAP_SCORE=62
TRADING_RISK_OFF_CAP=60
TRADING_VIX_SPIKE_PENALTY=10
TRADING_VIX_HARD=30.0
TRADING_VIX_SCALE_LOW=1.0
TRADING_VIX_SIZE_SCALE=0.5
TRADING_MAX_DAILY_LOSS=0.03
TRADING_MAX_WEEKLY_LOSS=0.07
# 포트 전체 오픈 리스크 상한(소수). NAV·종목당 리스크가 작으면 0.06은 1종만으로도 한도 도달 가능 → 테스트 시 완화
TRADING_MAX_PORT_HEAT=0.20
TRADING_TIME_STOP_DAYS=15
TRADING_MIN_DAILY_VOL=0
TRADING_MIN_TRADE_VALUE_KRW=0

# --- 보안 / 실행 ---
# [PIPELINE] 단계별 통과/차단 전체를 보려면 INFO (차단만 보면 기본 WARNING 도 중복 출력)
LOG_LEVEL=INFO
SECURE_STRICT=false
SKIP_KIS_ENV_VALIDATION=false
KIS_MIN_KEY_LEN=8
KIS_MIN_SECRET_LEN=8
KIS_HTTP_TIMEOUT=20
KIS_MAX_RETRIES=3
KIS_CB_FAILURES=5
KIS_CB_COOLDOWN_SEC=1800
KIS_MAX_PER_MINUTE=60
USE_KIS_REQUEST_GUARD=false
MAX_NOTIONAL_KRW_PER_DAY=0

# --- 주문·포지션 상태 ---
# market | limit(직전 기준가 지정가) | best_limit(최유리)
TRADING_ORDER_TYPE=market
# 사이클당 최대 신규 매수 건수 (점수 상위, MAX_OPEN_POSITIONS·heat 와 함께 적용)
TRADING_MAX_BUYS_PER_CYCLE=1
# 손절(hard_stop) 후 재진입 차단 일수
TRADING_REENTRY_BLOCK_DAYS=20
# 보유 중 추가매수(물타기): false 로 두면 같은 종목 추가 매수 가능 (기본 true=보유 중 재매수 안 함)
# SKIP_BUY_IF_HELD=true
# 매도 후 재매수: true(기본)면 익절·트레일 등 매도 후 신호 맞으면 다시 살 수 있음. 손절(hard_stop)만 REENTRY_BLOCK
TRADING_ALLOW_REBUY_AFTER_SELL=true
# 보유 중 같은 종목 연속 주문 방지(분). 매도 후에는 ALLOW_REBUY_AFTER_SELL 이 쿨다운 리셋
TRADING_BUY_COOLDOWN_MINUTES=60
# ALLOW_REBUY_AFTER_SELL=false 일 때만 당일 종목당 매수 횟수 상한
TRADING_MAX_BUYS_PER_SYMBOL_PER_DAY=1
TRADING_SKIP_BUY_IF_POSITION_STATE=true
# BUY_ATTEMPT_STATE_PATH=logs/buy_attempt_state.json
# POSITION_STATE_PATH=logs/position_state.json
# BLOCKED_SYMBOLS_PATH=logs/blocked_symbols.json
# 사이징·지정가 기준가: KIS 현재가 우선, 실패 시 FDR 종가
USE_KIS_QUOTE_FOR_SIZING=true
# 시장가 체결 가정 슬리피지(소수, 예: 0.005 = +0.5%)
TRADING_ENTRY_SLIPPAGE_BUFFER=0

# --- 한국장 breadth (FDR, 캐시) ---
USE_KR_BREADTH_FILTER=true
BREADTH_CACHE_SEC=1800
# breadth_score 가 이 값 미만이면 risk_off 강화(로그). 엔진 60점 상한은 TRADING_BREADTH_APPLY_RISK_OFF_CAP
BREADTH_RISK_OFF_BELOW=35
# true: breadth 약세만으로도 엔진 adjusted를 TRADING_RISK_OFF_CAP(60)으로 상한 (구동작)
TRADING_BREADTH_APPLY_RISK_OFF_CAP=false

# --- FDR / 매수 검증 ---
# 종목 일봉 캐시(초). 매수 스캔·TA·컨텍스트가 같은 종목을 1회만 FDR 조회 (기본 600)
# FDR_OHLCV_CACHE_SEC=600
# 종가 없음 스킵: 일봉 Close(FDR)를 못 받으면 해당 종목은 매수 계산 제외. false 유지·종목코드·네트워크 확인.
SKIP_FDR_SNAPSHOT=false
TRADING_CHASE_DAILY_PCT=0.15
TRADING_CHASE_BLOCK_DAYS=5
TRADING_BLOCK_RISK_OFF=true
TRADING_VALIDATE_MAX_NAME_PCT=
TRADING_MIN_STOCK_PRICE_KRW=0
USING_LEVERAGE=false
COMMUNITY_CHASE_FLAG=false
RECENT_AVG_DOWN_FLAG=false
TRADING_VALIDATE_STOCK_CTX_PYDANTIC=false

# --- 매크로 캘린더 ---
MACRO_CALENDAR_JSON=config/macro_dates.json
